@page "/log"
@using BlazorServerCPP.Models

<PageTitle>Log</PageTitle>

<div class="page-header">
    <h1>Log</h1>
    <button @onclick="Esporta">Esporta (txt)</button>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th style="width: 120px;">Tipo</th>
                <th>Contenuto</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in logs)
            {
                <tr>
                    <td>
                        <span class="badge badge-@(log.Tipo.ToLower() == "error" ? "admin" : log.Tipo.ToLower() == "warning" ? "installatore" : "user")">
                            @log.Tipo
                        </span>
                    </td>
                    <td>@log.Contenuto</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<Log> logs = new();

    protected override void OnInitialized()
    {
        logs = new List<Log>
        {
            new Log { Tipo = "Info",    Contenuto = "Sistema avviato" },
            new Log { Tipo = "Warning", Contenuto = "Connessione lenta" },
            new Log { Tipo = "Error",   Contenuto = "File non trovato" }
        };
    }

    private void Esporta()
    {
        // logica export
    }
}
