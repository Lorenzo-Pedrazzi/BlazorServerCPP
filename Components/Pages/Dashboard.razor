@page "/dashboard"
@using Microsoft.EntityFrameworkCore
@using BlazorServerCPP.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
</div>

<div class="card">
    <h3>Elenco clienti</h3>
    <p class="muted">Espandi un cliente per vedere le licenze associate.</p>

    @if (clients == null)
    {
        <p>Caricamento…</p>
    }
    else if (clients.Count == 0)
    {
        <div class="alert alert-info">Nessun cliente trovato.</div>
    }
    else
    {
        <ul class="tree">
            @foreach (var c in clients)
            {
                <li>
                    <button @onclick="() => Toggle(c.IdCliente)">
                        @(clientiAperti.Contains(c.IdCliente) ? "▼" : "▶") <strong>@c.Nome</strong>
                    </button>
                    @if (clientiAperti.Contains(c.IdCliente))
                    {
                        <ul>
                            @if (!c.Licenzes.Any())
                            {
                                <li class="muted">Nessuna licenza.</li>
                            }
                            else
                            {
                                @foreach (var l in c.Licenzes)
                                {
                                    <li>
                                        <code>@l.IdLicenza</code>
                                        &mdash; attivata il @l.DataAttivazione?.ToString("dd/MM/yyyy")
                                    </li>
                                }
                            }
                        </ul>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    private List<BlazorServerCPP.Models.Clienti>? clients;
    private HashSet<string> clientiAperti = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        clients = await db.Clienti.Include(c => c.Licenzes).OrderBy(c => c.Nome).ToListAsync();
    }

    private void Toggle(string idCliente)
    {
        if (!clientiAperti.Add(idCliente))
            clientiAperti.Remove(idCliente);
    }
}
