@inherits LayoutComponentBase

<div class="layout">
    <aside class="sidebar">
        <div class="brand">Blazor Server CPP</div>
        <nav>
            <ul>
                <li><NavLink href="/" Match="NavLinkMatch.All">Home</NavLink></li>
                <li><NavLink href="/dashboard">Dashboard</NavLink></li>
                <li><NavLink href="/configurazione">Configurazione</NavLink></li>
                <li><NavLink href="/log">Log</NavLink></li>
            </ul>
        </nav>

        <AuthorizeView>
            <Authorized>
                <div class="user-box">
                    <div class="user">
                        Collegato come
                        <div class="username">@context.User.Identity?.Name</div>
                    </div>
                    <form action="/auth/logout" method="post">
                        <button type="submit" class="btn-ghost btn-block">Logout</button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </aside>

    <main class="content">
        @Body
    </main>
</div>
